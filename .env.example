# SerpAPI key for Google Patents search
# https://serpapi.com/ で取得
SERPAPI_KEY=your_serpapi_key_here

# --- Flask 起動設定 ---
# 接続許可するホスト。LAN 公開時のみ 0.0.0.0 に変更
PATENT_COMPARE_HOST=127.0.0.1
PATENT_COMPARE_PORT=5000
# 1 にするとデバッガが有効になる (開発時のみ)。LAN 公開時は必ず 0
PATENT_COMPARE_DEBUG=0

# Flask セッション署名用キー。未設定時は .secret_key ファイルに自動生成される。
# 例: python -c "import secrets; print(secrets.token_urlsafe(48))"
# PATENT_COMPARE_SECRET_KEY=
